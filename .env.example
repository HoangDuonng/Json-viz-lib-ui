# Internal API base for this Next.js app
NEXT_PUBLIC_API_URL=https://hello-how-a-u.example/api/v1

# Keep these aligned with Json-viz (Draw) environment:
# - VITE_APP_LIBRARY_URL
# - LIBRARY_BACKEND_URL
NEXT_PUBLIC_LIBRARY_SITE_URL=https://hello-library-site.example
LIBRARY_BACKEND_URL=https://hello-library-backend.example
NEXT_PUBLIC_JSONVIZ_APP_URL=https://hello-jsonviz-app.example
NEXT_PUBLIC_JSONVIZ_DRAW_URL=https://hello-jsonviz-app.example/draw

# Library source used by /api/v1/libraries
LIBRARY_SOURCE_OWNER=
LIBRARY_SOURCE_REPO=
LIBRARY_SOURCE_PATH=
LIBRARY_SOURCE_REF=hi

# Optional, but recommended to avoid API rate limits
# LIBRARY_SOURCE_TOKEN=
