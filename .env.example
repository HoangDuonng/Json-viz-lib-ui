# Internal API base for this Next.js app
NEXT_PUBLIC_API_URL=https://hello-how-a-u.example/api/v1

# Keep these aligned with Json-viz (Draw) environment:
# - VITE_APP_LIBRARY_URL
# - VITE_APP_LIBRARY_BACKEND
NEXT_PUBLIC_LIBRARY_SITE_URL=https://hello-library-site.example
NEXT_PUBLIC_LIBRARY_BACKEND_URL=https://hello-library-backend.example
NEXT_PUBLIC_JSONVIZ_APP_URL=https://hello-jsonviz-app.example

# GitHub source used by /api/v1/libraries
LIBRARY_GITHUB_OWNER=hello-how-a-u-owner
LIBRARY_GITHUB_REPO=hello-how-a-u-repo
LIBRARY_GITHUB_PATH=hello-how-a-u-path
LIBRARY_GITHUB_REF=hello-how-a-u-branch

# Optional, but recommended to avoid GitHub API rate limits
# GITHUB_TOKEN=hello-how-a-u-token
